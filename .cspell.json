{
  "version": "0.2",
  "language": "en",
  "words": [],
  "dictionaries": ["project-words"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": ".cspell/project-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "*.json",
    "*.yml",
    "*.yaml"
  ],
  "files": [
    "**/*.md"
  ],
  "ignoreRegExpList": [
    "/```[\\s\\S]*?```/g",
    "/`[^`]+`/g",
    "/<[^>]+>/g",
    "/\\[.*?\\]\\(.*?\\)/g",
    "/https?:\\/\\/[^\\s)]+/g"
  ],
  "minWordLength": 3,
  "allowCompoundWords": true
}
