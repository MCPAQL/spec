{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/field-selection.schema.json",
  "title": "MCP-AQL Field Selection",
  "description": "Schema for MCP-AQL field selection parameters enabling clients to request specific fields in responses",

  "$defs": {
    "FieldSelectionPreset": {
      "type": "string",
      "enum": ["minimal", "standard", "full"],
      "description": "Predefined field selection presets. 'minimal' returns essential identification fields only, 'standard' returns common fields for typical use, 'full' returns all available fields."
    },

    "FieldPath": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$",
      "description": "A field path using dot notation for nested properties (e.g., 'settings.theme')"
    },
    "ComputedFieldPath": {
      "type": "string",
      "pattern": "^_computed\\.[a-z][a-z0-9_]*$",
      "description": "A computed field path using the `_computed.` prefix (e.g., '_computed.age_days')"
    },
    "SelectableFieldPath": {
      "oneOf": [
        {
          "$ref": "#/$defs/FieldPath"
        },
        {
          "$ref": "#/$defs/ComputedFieldPath"
        }
      ]
    },

    "FieldSelectionInput": {
      "type": "object",
      "description": "Field selection parameters for operation requests",
      "properties": {
        "fields": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/SelectableFieldPath"
              },
              "description": "Array of specific field names/paths to include"
            },
            {
              "$ref": "#/$defs/FieldSelectionPreset",
              "description": "A preset name for convenience"
            }
          ],
          "description": "Preferred field-selection control. Accepts either an explicit array of field paths or a preset name such as 'minimal'."
        },
        "preset": {
          "$ref": "#/$defs/FieldSelectionPreset",
          "description": "Compatibility alias for preset selection. New request shapes SHOULD prefer `fields: \"minimal\"` instead.",
          "deprecated": true
        }
      },
      "additionalProperties": false
    },

    "FieldDefinition": {
      "type": "object",
      "description": "Definition of an available field for introspection",
      "properties": {
        "name": {
          "type": "string",
          "description": "Field name (snake_case)"
        },
        "type": {
          "type": "string",
          "description": "Field data type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable field description"
        },
        "nested": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FieldDefinition"
          },
          "description": "Nested field definitions for object types"
        }
      },
      "required": ["name", "type"],
      "additionalProperties": false
    },
    "ComputedFieldInfo": {
      "type": "object",
      "description": "Definition of a computed field exposed by the adapter",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Computed field name without the `_computed.` prefix"
        },
        "type": {
          "type": "string",
          "description": "Computed field data type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable computed field description"
        },
        "filterable": {
          "type": "boolean",
          "description": "Whether the computed field can be used in filter clauses"
        },
        "sortable": {
          "type": "boolean",
          "description": "Whether the computed field can be used in sort clauses"
        }
      },
      "required": ["name", "type"],
      "additionalProperties": false
    },

    "PresetDefinition": {
      "type": "object",
      "description": "Definition of a field selection preset",
      "properties": {
        "name": {
          "type": "string",
          "description": "Preset name"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SelectableFieldPath"
          },
          "description": "Fields included in this preset"
        },
        "description": {
          "type": "string",
          "description": "Human-readable preset description"
        }
      },
      "required": ["name", "fields"],
      "additionalProperties": false
    },

    "FieldSelectionMetadata": {
      "type": "object",
      "description": "Introspection metadata for field selection capabilities",
      "properties": {
        "supported": {
          "type": "boolean",
          "description": "Whether field selection is supported for this operation/type"
        },
        "presets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PresetDefinition"
          },
          "description": "Available presets"
        },
        "available_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FieldDefinition"
          },
          "description": "All available fields that can be selected"
        },
        "computed_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ComputedFieldInfo"
          },
          "description": "Adapter-declared computed fields available through `_computed.` paths"
        },
        "default_preset": {
          "$ref": "#/$defs/FieldSelectionPreset",
          "description": "Default preset when no selection specified"
        }
      },
      "required": ["supported"],
      "additionalProperties": false
    }
  },

  "type": "object",
  "description": "Complete field selection schema combining input and metadata",
  "properties": {
    "input": {
      "$ref": "#/$defs/FieldSelectionInput"
    },
    "metadata": {
      "$ref": "#/$defs/FieldSelectionMetadata"
    }
  },
  "additionalProperties": false,

  "examples": [
    {
      "input": {
        "fields": ["id", "name", "email"]
      }
    },
    {
      "input": {
        "fields": "minimal"
      }
    },
    {
      "input": {
        "preset": "minimal",
        "fields": ["created_at"]
      }
    },
    {
      "input": {
        "fields": ["id", "name", "settings.theme", "settings.language", "_computed.age_days"]
      }
    },
    {
      "metadata": {
        "supported": true,
        "presets": [
          { "name": "minimal", "fields": ["id", "name"], "description": "Essential identification fields" },
          { "name": "standard", "fields": ["id", "name", "email", "created_at"], "description": "Common fields" },
          { "name": "full", "fields": ["id", "name", "email", "created_at", "updated_at", "metadata"], "description": "All fields" }
        ],
        "computed_fields": [
          { "name": "age_days", "type": "number", "description": "Days since creation", "filterable": true, "sortable": true }
        ],
        "available_fields": [
          { "name": "id", "type": "string", "description": "Unique identifier" },
          { "name": "name", "type": "string", "description": "Display name" },
          { "name": "email", "type": "string", "description": "Email address" },
          { "name": "settings", "type": "object", "description": "User settings", "nested": [
            { "name": "theme", "type": "string", "description": "UI theme preference" },
            { "name": "language", "type": "string", "description": "Language preference" }
          ]}
        ],
        "default_preset": "standard"
      }
    }
  ]
}
