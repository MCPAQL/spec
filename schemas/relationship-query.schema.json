{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/relationship-query.schema.json",
  "title": "MCP-AQL Relationship Query",
  "description": "Informative helper schema for the preferred MCP-AQL relationship-query request and capability shapes.",
  "$defs": {
    "Direction": {
      "type": "string",
      "enum": ["incoming", "outgoing", "both"]
    },
    "RootReference": {
      "type": "object",
      "properties": {
        "element_type": {
          "type": "string"
        },
        "element_name": {
          "type": "string"
        }
      },
      "required": ["element_type", "element_name"],
      "additionalProperties": false
    },
    "RelationshipCapabilities": {
      "type": "object",
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "directions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Direction"
          }
        },
        "relationship_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["supported"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "root": {
          "$ref": "#/$defs/RootReference"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "relationship": {
          "type": "string"
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["root", "direction"],
      "additionalProperties": true
    },
    "relationship_capabilities": {
      "$ref": "#/$defs/RelationshipCapabilities"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "request": {
        "root": {
          "element_type": "agent",
          "element_name": "code_reviewer"
        },
        "direction": "outgoing",
        "relationship": "uses",
        "depth": 2
      }
    },
    {
      "relationship_capabilities": {
        "supported": true,
        "directions": ["incoming", "outgoing", "both"],
        "relationship_types": ["uses", "extends", "references", "triggers", "composes"],
        "max_depth": 3
      }
    }
  ]
}
