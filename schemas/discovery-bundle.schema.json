{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/discovery-bundle.schema.json",
  "title": "MCP Server Discovery Bundle",
  "description": "Intermediate artifact capturing raw MCP server tool metadata plus normalized generator-facing interpretations for MCP-AQL adapter synthesis.",
  "x-normative": false,
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "1.0.0-draft",
      "description": "Discovery-bundle artifact version. This is versioned independently from the normative operation schemas."
    },
    "source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "server_url": { "type": "string", "format": "uri" },
        "transport": {
          "type": "string",
          "enum": ["streamable_http"],
          "description": "Transport used during capture. The current minimal contract only standardizes streamable_http."
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "server": {
          "type": "object",
          "description": "Optional server identity metadata returned during MCP initialization when the source server exposes it.",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "title": { "type": "string" }
          },
          "additionalProperties": false
        },
        "auth": {
          "type": "object",
          "description": "Redacted auth metadata used during capture. The current minimal contract recognizes bearer and none.",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bearer", "none"]
            },
            "header": { "type": "string" },
            "prefix": { "type": "string" },
            "token_env": { "type": "string" },
            "token_command": { "type": "string" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        "capture_config_redacted": {
          "type": "object"
        }
      },
      "required": ["name", "server_url", "transport", "captured_at", "auth", "capture_config_redacted"],
      "additionalProperties": false
    },
    "raw_capture": {
      "type": "object",
      "description": "Opaque source facts captured directly from the MCP server. Additional upstream response metadata MAY be preserved here alongside tools.",
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["tools"],
      "additionalProperties": true
    },
    "normalized_bundle": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_tool_name": { "type": "string" },
              "operation_name": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "endpoint": {
                "type": "string",
                "enum": ["CREATE", "READ", "UPDATE", "DELETE", "EXECUTE"]
              },
              "endpoint_confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "danger_level": {
                "type": "string",
                "enum": ["safe", "reversible", "destructive", "dangerous", "forbidden"],
                "description": "Suggested danger level for downstream schema generation. This may be heuristic or manually reviewed rather than source-declared."
              },
              "needs_review": { "type": "boolean" },
              "review_reasons": {
                "type": "array",
                "items": { "type": "string" }
              },
              "params": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "original_name": { "type": "string" },
                    "type": { "type": "string" },
                    "required": { "type": "boolean" },
                    "description": { "type": "string" },
                    "default": {},
                    "enum": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "minimum": { "type": "number" },
                    "maximum": { "type": "number" },
                    "pattern": { "type": "string" },
                    "format": { "type": "string" },
                    "source_path": {
                      "type": "string",
                      "description": "Dot-path into the raw upstream tool object, for example 'inputSchema.properties.owner'."
                    }
                  },
                  "required": ["name", "original_name", "type", "required", "source_path"],
                  "additionalProperties": false
                }
              },
              "maps_to": {
                "type": "string",
                "description": "Generator-facing routing target. This may be a deterministic proxy mapping or a manually reviewed suggestion rather than a source-declared API route."
              },
              "returns": {
                "type": "object",
                "properties": {
                  "type": {
                    "const": "object",
                    "description": "Discovery bundles normalize wrapped operation results to an object envelope even when the upstream MCP tool returns non-object domain content."
                  },
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                },
                "required": ["type", "name", "description"],
                "additionalProperties": false
              },
              "provenance": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Source field or attribute used as the basis for the normalized operation name, for example 'name'."
                  },
                  "description": {
                    "type": "string",
                    "description": "Source field used as the basis for the normalized operation description, for example 'description'."
                  },
                  "annotations": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "input_schema_present": { "type": "boolean" },
                  "inference_sources": {
                    "type": "object",
                    "description": "Machine-readable classification of how key normalized fields were derived.",
                    "properties": {
                      "operation_name": {
                        "type": "string",
                        "enum": ["direct_source_metadata", "deterministic_normalization", "heuristic_classification", "manual_override"]
                      },
                      "description": {
                        "type": "string",
                        "enum": ["direct_source_metadata", "deterministic_normalization", "heuristic_classification", "manual_override"]
                      },
                      "endpoint": {
                        "type": "string",
                        "enum": ["direct_source_metadata", "deterministic_normalization", "heuristic_classification", "manual_override"]
                      },
                      "danger_level": {
                        "type": "string",
                        "enum": ["direct_source_metadata", "deterministic_normalization", "heuristic_classification", "manual_override"]
                      },
                      "maps_to": {
                        "type": "string",
                        "enum": ["direct_source_metadata", "deterministic_normalization", "heuristic_classification", "manual_override"]
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": ["name", "input_schema_present"],
                "additionalProperties": false
              }
            },
            "required": [
              "source_tool_name",
              "operation_name",
              "description",
              "endpoint",
              "endpoint_confidence",
              "danger_level",
              "needs_review",
              "review_reasons",
              "params",
              "maps_to",
              "returns",
              "provenance"
            ],
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["info", "warning", "error"]
              },
              "message": { "type": "string" },
              "tool": { "type": "string" },
              "field": { "type": "string" },
              "heuristic": { "type": "string" }
            },
            "required": ["code", "severity", "message"],
            "additionalProperties": false
          }
        }
      },
      "required": ["operations", "warnings"],
      "additionalProperties": false
    }
  },
  "required": ["schema_version", "source", "raw_capture", "normalized_bundle"],
  "additionalProperties": false
}
