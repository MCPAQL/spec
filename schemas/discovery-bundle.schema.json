{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/discovery-bundle.schema.json",
  "title": "MCP Server Discovery Bundle",
  "description": "Intermediate artifact capturing raw MCP server tool metadata plus normalized generator-facing interpretations for MCP-AQL adapter synthesis.",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "server_url": { "type": "string", "format": "uri" },
        "transport": {
          "type": "string",
          "enum": ["streamable_http"]
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "server": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "title": { "type": "string" }
          },
          "additionalProperties": false
        },
        "auth": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bearer", "none"]
            },
            "header": { "type": "string" },
            "prefix": { "type": "string" },
            "token_env": { "type": "string" },
            "token_command": { "type": "string" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        "capture_config_redacted": {
          "type": "object"
        }
      },
      "required": ["name", "server_url", "transport", "captured_at", "auth", "capture_config_redacted"],
      "additionalProperties": false
    },
    "raw_capture": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["tools"],
      "additionalProperties": false
    },
    "normalized_bundle": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_tool_name": { "type": "string" },
              "operation_name": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "endpoint": {
                "type": "string",
                "enum": ["CREATE", "READ", "UPDATE", "DELETE", "EXECUTE"]
              },
              "endpoint_confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "danger_level": {
                "type": "string",
                "enum": ["safe", "reversible", "destructive", "dangerous", "forbidden"]
              },
              "needs_review": { "type": "boolean" },
              "review_reasons": {
                "type": "array",
                "items": { "type": "string" }
              },
              "params": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "original_name": { "type": "string" },
                    "type": { "type": "string" },
                    "required": { "type": "boolean" },
                    "description": { "type": "string" },
                    "default": {},
                    "enum": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "minimum": { "type": "number" },
                    "maximum": { "type": "number" },
                    "pattern": { "type": "string" },
                    "format": { "type": "string" },
                    "source_path": { "type": "string" }
                  },
                  "required": ["name", "original_name", "type", "required", "source_path"],
                  "additionalProperties": false
                }
              },
              "maps_to": { "type": "string" },
              "returns": {
                "type": "object",
                "properties": {
                  "type": { "const": "object" },
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                },
                "required": ["type", "name", "description"],
                "additionalProperties": false
              },
              "provenance": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "annotations": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "input_schema_present": { "type": "boolean" }
                },
                "required": ["name", "input_schema_present"],
                "additionalProperties": false
              }
            },
            "required": [
              "source_tool_name",
              "operation_name",
              "description",
              "endpoint",
              "endpoint_confidence",
              "danger_level",
              "needs_review",
              "review_reasons",
              "params",
              "maps_to",
              "returns",
              "provenance"
            ],
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["info", "warning", "error"]
              },
              "message": { "type": "string" },
              "tool": { "type": "string" },
              "field": { "type": "string" },
              "heuristic": { "type": "string" }
            },
            "required": ["code", "severity", "message"],
            "additionalProperties": false
          }
        }
      },
      "required": ["operations", "warnings"],
      "additionalProperties": false
    }
  },
  "required": ["schema_version", "source", "raw_capture", "normalized_bundle"],
  "additionalProperties": false
}
