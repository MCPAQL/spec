{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/introspection-response.schema.json",
  "title": "MCP-AQL Introspection Response",
  "description": "Schema for MCP-AQL introspection operation responses. Introspection enables runtime discovery of operations, types, and capabilities.",

  "$defs": {
    "SemanticCategory": {
      "type": "string",
      "enum": ["CREATE", "READ", "UPDATE", "DELETE", "EXECUTE"],
      "description": "Standard semantic categories for operation classification"
    },

    "EndpointFamily": {
      "type": "string",
      "minLength": 1,
      "description": "Exposed endpoint family name or logical tool grouping for an operation"
    },

    "TypeKind": {
      "type": "string",
      "enum": ["enum", "object", "scalar", "union"],
      "description": "The kind of type definition"
    },

    "EndpointPermissions": {
      "type": "object",
      "description": "Permission flags indicating operation characteristics",
      "properties": {
        "readOnly": {
          "type": "boolean",
          "description": "Whether operation only reads state without modification"
        },
        "destructive": {
          "type": "boolean",
          "description": "Whether operation removes or destroys state"
        }
      },
      "required": ["readOnly", "destructive"],
      "additionalProperties": false
    },

    "ParameterInfo": {
      "type": "object",
      "description": "Parameter definition for an operation, including validation constraints",
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name (snake_case recommended)"
        },
        "type": {
          "type": "string",
          "description": "Type name (e.g., 'string', 'number', 'boolean', 'array', 'object', or adapter-defined types)"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the parameter is required"
        },
        "description": {
          "type": "string",
          "description": "Human-readable parameter description"
        },
        "default": {
          "description": "Default value if parameter is not provided"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values for this parameter (enables client-side validation and LLM guidance)"
        },
        "minimum": {
          "type": "number",
          "description": "Minimum value for numeric parameters (inclusive)"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum value for numeric parameters (inclusive)"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum length for string parameters"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum length for string parameters"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for string validation"
        },
        "format": {
          "type": "string",
          "description": "Semantic format hint (e.g., 'date-time', 'email', 'uri', 'uuid')"
        },
        "items": {
          "type": "object",
          "description": "Schema for array element types (nested ParameterInfo)"
        },
        "sensitive": {
          "type": "boolean",
          "default": false,
          "description": "Whether parameter contains sensitive data (passwords, API keys) - clients SHOULD mask input"
        }
      },
      "required": ["name", "type", "required"],
      "additionalProperties": false
    },

    "OperationInfo": {
      "type": "object",
      "description": "Summary information for an operation (used in list responses)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Operation identifier (e.g., 'create_entity')"
        },
        "semantic_category": {
          "$ref": "#/$defs/SemanticCategory",
          "description": "Standard semantic category for the operation"
        },
        "endpoint": {
          "$ref": "#/$defs/EndpointFamily",
          "description": "Exposed endpoint family this operation belongs to"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the operation"
        }
      },
      "required": ["name", "semantic_category", "endpoint", "description"],
      "additionalProperties": false
    },

    "TypeInfo": {
      "type": "object",
      "description": "Summary information for a type (used in list responses)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Type identifier"
        },
        "kind": {
          "$ref": "#/$defs/TypeKind",
          "description": "The kind of type"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the type"
        }
      },
      "required": ["name", "kind"],
      "additionalProperties": false
    },

    "ExecutionState": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "cancelled"],
      "description": "Core execution lifecycle states"
    },

    "LifecycleInfo": {
      "type": "object",
      "description": "Execution lifecycle metadata for EXECUTE operations that manage long-running processes",
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Supported execution states (core states plus any adapter extensions)"
        },
        "supports_cancel": {
          "type": "boolean",
          "default": false,
          "description": "Whether the operation supports cancellation"
        },
        "supports_retry": {
          "type": "boolean",
          "default": false,
          "description": "Whether failed executions can be retried"
        },
        "progress_reporting": {
          "type": "boolean",
          "default": false,
          "description": "Whether the operation reports progress updates"
        }
      },
      "required": ["states"],
      "additionalProperties": false
    },
    "ComputedFieldInfo": {
      "type": "object",
      "description": "Metadata describing an adapter-declared computed field",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Computed field name without the `_computed.` prefix"
        },
        "type": {
          "type": "string",
          "description": "Computed field type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable computed field description"
        },
        "filterable": {
          "type": "boolean",
          "description": "Whether the computed field can be used in filters"
        },
        "sortable": {
          "type": "boolean",
          "description": "Whether the computed field can be used in sorting"
        }
      },
      "required": ["name", "type"],
      "additionalProperties": false
    },
    "AggregationSupport": {
      "type": "object",
      "description": "Metadata describing server-side aggregation support for an operation",
      "properties": {
        "supported": {
          "type": "boolean",
          "description": "Whether aggregation is supported"
        },
        "default_mode": {
          "type": "string",
          "enum": ["summary_only", "include_items"],
          "description": "Default response mode when `aggregate` is present"
        },
        "functions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["count", "group_by", "sum", "avg", "min", "max"]
          },
          "description": "Supported aggregation functions"
        },
        "groupable_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fields that can be used with `group_by`"
        },
        "numeric_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fields that can be used with numeric aggregations"
        }
      },
      "required": ["supported"],
      "additionalProperties": false
    },
    "RelationshipCapabilities": {
      "type": "object",
      "description": "Metadata describing relationship-query support for an operation",
      "properties": {
        "supported": {
          "type": "boolean",
          "description": "Whether relationship traversal is supported"
        },
        "directions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["incoming", "outgoing", "both"]
          },
          "description": "Supported traversal directions"
        },
        "relationship_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Supported relationship types"
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum supported traversal depth"
        }
      },
      "required": ["supported"],
      "additionalProperties": false
    },

    "OperationDetails": {
      "type": "object",
      "description": "Complete information for a specific operation",
      "properties": {
        "name": {
          "type": "string",
          "description": "Operation identifier"
        },
        "semantic_category": {
          "$ref": "#/$defs/SemanticCategory",
          "description": "Standard semantic category for the operation"
        },
        "endpoint": {
          "$ref": "#/$defs/EndpointFamily",
          "description": "Exposed endpoint family this operation belongs to"
        },
        "mcpTool": {
          "type": "string",
          "description": "Actual MCP tool name handling the operation (e.g., 'mcp_aql_query')"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the operation"
        },
        "permissions": {
          "$ref": "#/$defs/EndpointPermissions",
          "description": "Permission flags for this operation"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterInfo"
          },
          "description": "Parameter definitions for the operation"
        },
        "returns": {
          "$ref": "#/$defs/TypeInfo",
          "description": "Return type information"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable description of the example"
              },
              "request": {
                "type": "object",
                "description": "Example request object"
              }
            },
            "required": ["request"],
            "additionalProperties": false
          },
          "description": "Example invocations of the operation"
        },
        "computed_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ComputedFieldInfo"
          },
          "description": "Computed fields that may be requested through `_computed.` field paths"
        },
        "aggregation_support": {
          "$ref": "#/$defs/AggregationSupport",
          "description": "Aggregation capabilities for this operation"
        },
        "relationship_capabilities": {
          "$ref": "#/$defs/RelationshipCapabilities",
          "description": "Relationship traversal capabilities for this operation"
        },
        "lifecycle": {
          "$ref": "#/$defs/LifecycleInfo",
          "description": "Execution lifecycle metadata (for EXECUTE operations that manage long-running processes)"
        }
      },
      "required": ["name", "semantic_category", "endpoint", "mcpTool", "description", "permissions", "parameters", "returns"],
      "additionalProperties": false
    },

    "TypeDetails": {
      "description": "Complete information for a specific type",
      "oneOf": [
        {
          "type": "object",
          "title": "Enum Type Details",
          "properties": {
            "name": {
              "type": "string",
              "description": "Type identifier"
            },
            "kind": {
              "const": "enum",
              "description": "The kind of type"
            },
            "description": {
              "type": "string",
              "description": "Detailed description of the type"
            },
            "values": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed values for the enum type"
            }
          },
          "required": ["name", "kind", "values"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "title": "Object Type Details",
          "properties": {
            "name": {
              "type": "string",
              "description": "Type identifier"
            },
            "kind": {
              "const": "object",
              "description": "The kind of type"
            },
            "description": {
              "type": "string",
              "description": "Detailed description of the type"
            },
            "fields": {
              "type": "array",
              "items": { "$ref": "#/$defs/ParameterInfo" },
              "description": "Field definitions for the object type"
            }
          },
          "required": ["name", "kind", "fields"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "title": "Union Type Details",
          "properties": {
            "name": {
              "type": "string",
              "description": "Type identifier"
            },
            "kind": {
              "const": "union",
              "description": "The kind of type"
            },
            "description": {
              "type": "string",
              "description": "Detailed description of the type"
            },
            "members": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Member type names in the union"
            }
          },
          "required": ["name", "kind", "members"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "title": "Scalar Type Details",
          "properties": {
            "name": {
              "type": "string",
              "description": "Type identifier"
            },
            "kind": {
              "const": "scalar",
              "description": "The kind of type"
            },
            "description": {
              "type": "string",
              "description": "Detailed description of the type"
            }
          },
          "required": ["name", "kind"],
          "additionalProperties": false
        }
      ]
    },

    "ProtocolCapabilities": {
      "type": "object",
      "description": "Feature flags for optional protocol capabilities",
      "properties": {
        "batch": {
          "type": "boolean",
          "description": "Supports batch operations"
        },
        "field_selection": {
          "type": "boolean",
          "description": "Supports field selection in responses"
        },
        "aggregations": {
          "type": "boolean",
          "description": "Supports server-side aggregations on collection operations"
        },
        "computed_fields": {
          "type": "boolean",
          "description": "Exposes adapter-declared computed fields"
        },
        "pagination": {
          "type": "boolean",
          "description": "Supports cursor-based pagination"
        },
        "relationship_queries": {
          "type": "boolean",
          "description": "Supports graph and relationship traversal queries"
        },
        "warnings": {
          "type": "boolean",
          "description": "Includes warnings array in responses"
        },
        "confirmation": {
          "type": "boolean",
          "description": "Supports confirmation token flow for dangerous operations"
        },
        "dangerous_operations": {
          "type": "boolean",
          "description": "Has danger level classification for operations"
        }
      },
      "additionalProperties": true
    },

    "ProtocolMetadata": {
      "type": "object",
      "description": "Protocol version and capability information",
      "properties": {
        "version": {
          "type": "string",
          "description": "MCP-AQL specification version (semver format)",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
        },
        "conformance": {
          "type": "string",
          "description": "Conformance level",
          "enum": ["level-1", "level-2"]
        },
        "mode": {
          "type": "string",
          "description": "Endpoint mode",
          "enum": ["semantic", "single", "all"]
        },
        "capabilities": {
          "$ref": "#/$defs/ProtocolCapabilities",
          "description": "Optional feature capabilities"
        }
      },
      "required": ["version"],
      "additionalProperties": true
    },

    "OperationsListData": {
      "type": "object",
      "description": "Response data for listing all operations",
      "properties": {
        "_protocol": {
          "$ref": "#/$defs/ProtocolMetadata",
          "description": "Protocol version and capability metadata"
        },
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OperationInfo"
          },
          "description": "List of available operations"
        }
      },
      "required": ["operations"],
      "additionalProperties": false
    },

    "OperationDetailData": {
      "type": "object",
      "description": "Response data for a specific operation query",
      "properties": {
        "operation": {
          "oneOf": [
            { "$ref": "#/$defs/OperationDetails" },
            { "type": "null" }
          ],
          "description": "Operation details, or null if not found"
        }
      },
      "required": ["operation"],
      "additionalProperties": false
    },

    "TypesListData": {
      "type": "object",
      "description": "Response data for listing all types",
      "properties": {
        "types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TypeInfo"
          },
          "description": "List of available types"
        }
      },
      "required": ["types"],
      "additionalProperties": false
    },

    "TypeDetailData": {
      "type": "object",
      "description": "Response data for a specific type query",
      "properties": {
        "type": {
          "oneOf": [
            { "$ref": "#/$defs/TypeDetails" },
            { "type": "null" }
          ],
          "description": "Type details, or null if not found"
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },

    "IntrospectionData": {
      "description": "Introspection response data (varies by query type)",
      "oneOf": [
        {
          "$ref": "#/$defs/OperationsListData",
          "title": "Operations List",
          "description": "Response for query: 'operations' without name parameter"
        },
        {
          "$ref": "#/$defs/OperationDetailData",
          "title": "Operation Details",
          "description": "Response for query: 'operations' with name parameter"
        },
        {
          "$ref": "#/$defs/TypesListData",
          "title": "Types List",
          "description": "Response for query: 'types' without name parameter"
        },
        {
          "$ref": "#/$defs/TypeDetailData",
          "title": "Type Details",
          "description": "Response for query: 'types' with name parameter"
        }
      ]
    },

    "IntrospectionError": {
      "type": "object",
      "description": "Error information for failed introspection",
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code",
          "examples": ["INTROSPECTION_ERROR", "INVALID_QUERY_TYPE", "INTERNAL_ERROR"]
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        }
      },
      "required": ["code", "message"],
      "additionalProperties": false
    }
  },

  "oneOf": [
    {
      "type": "object",
      "title": "Success Response",
      "description": "Successful introspection response",
      "properties": {
        "success": {
          "const": true,
          "description": "Indicates introspection succeeded"
        },
        "data": {
          "$ref": "#/$defs/IntrospectionData",
          "description": "Introspection result data"
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Failure Response",
      "description": "Failed introspection response",
      "properties": {
        "success": {
          "const": false,
          "description": "Indicates introspection failed"
        },
        "error": {
          "$ref": "#/$defs/IntrospectionError",
          "description": "Error information"
        }
      },
      "required": ["success", "error"],
      "additionalProperties": false
    }
  ],

  "examples": [
    {
      "success": true,
      "data": {
        "_protocol": {
          "version": "1.0.0-alpha.1",
          "conformance": "level-1",
          "mode": "semantic",
          "capabilities": {
            "batch": false,
            "field_selection": true,
            "aggregations": true,
            "computed_fields": true,
            "pagination": true,
            "relationship_queries": true,
            "warnings": true,
            "confirmation": true,
            "dangerous_operations": true
          }
        },
        "operations": [
          {
            "name": "create_entity",
            "semantic_category": "CREATE",
            "endpoint": "manage",
            "description": "Create a new entity"
          },
          {
            "name": "list_entities",
            "semantic_category": "READ",
            "endpoint": "query",
            "description": "List entities with filtering"
          },
          {
            "name": "introspect",
            "semantic_category": "READ",
            "endpoint": "query",
            "description": "Discover available operations and types"
          }
        ]
      }
    },
    {
      "success": true,
      "data": {
        "operation": {
          "name": "create_entity",
          "semantic_category": "CREATE",
          "endpoint": "manage",
          "mcpTool": "mcp_aql_manage",
          "description": "Create a new entity of any type",
          "permissions": {
            "readOnly": false,
            "destructive": false
          },
          "parameters": [
            {
              "name": "entity_name",
              "type": "string",
              "required": true,
              "description": "Entity name",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
            },
            {
              "name": "entity_type",
              "type": "string",
              "required": true,
              "description": "Type of entity to create",
              "enum": ["resource", "item", "config", "workflow"]
            },
            {
              "name": "priority",
              "type": "integer",
              "required": false,
              "description": "Priority level (1-10)",
              "default": 5,
              "minimum": 1,
              "maximum": 10
            },
            {
              "name": "api_key",
              "type": "string",
              "required": false,
              "description": "Optional API key for external integration",
              "sensitive": true
            }
          ],
          "returns": {
            "name": "Entity",
            "kind": "object",
            "description": "Newly created entity"
          },
          "computed_fields": [
            {
              "name": "age_days",
              "type": "number",
              "description": "Days since creation",
              "filterable": true,
              "sortable": true
            }
          ],
          "aggregation_support": {
            "supported": true,
            "default_mode": "summary_only",
            "functions": ["count", "group_by"],
            "groupable_fields": ["entity_type"],
            "numeric_fields": ["priority"]
          },
          "examples": [
            {
              "description": "Create a basic entity",
              "request": {
                "operation": "create_entity",
                "params": { "entity_name": "MyEntity" }
              }
            }
          ]
        }
      }
    },
    {
      "success": true,
      "data": {
        "operation": null
      }
    },
    {
      "success": true,
      "data": {
        "types": [
          {
            "name": "EntityType",
            "kind": "enum",
            "description": "Available entity types"
          },
          {
            "name": "OperationResult",
            "kind": "union",
            "description": "Standard result type for all operations"
          }
        ]
      }
    },
    {
      "success": true,
      "data": {
        "type": {
          "name": "EntityType",
          "kind": "enum",
          "description": "Available entity types",
          "values": ["resource", "item", "config", "workflow"]
        }
      }
    },
    {
      "success": false,
      "error": {
        "code": "INVALID_QUERY_TYPE",
        "message": "Unknown query type: 'invalid'. Supported types: operations, types"
      }
    }
  ]
}
