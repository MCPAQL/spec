{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/batch-operation.schema.json",
  "title": "MCP-AQL Batch Operation",
  "description": "Schema for MCP-AQL batch operation request and response formats",

  "$defs": {
    "BatchOperationItem": {
      "type": "object",
      "description": "A single operation within a batch request",
      "properties": {
        "operation": {
          "type": "string",
          "description": "The operation name to execute (snake_case)",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "params": {
          "type": "object",
          "description": "Operation parameters (adapter-specific)",
          "additionalProperties": true
        }
      },
      "required": ["operation"],
      "additionalProperties": true
    },

    "OperationResult": {
      "description": "Discriminated union result for a single operation",
      "oneOf": [
        {
          "type": "object",
          "title": "Success Result",
          "properties": {
            "success": { "const": true },
            "data": { "description": "Operation result data" }
          },
          "required": ["success", "data"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "title": "Failure Result",
          "properties": {
            "success": { "const": false },
            "error": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "required": ["code", "message"]
            }
          },
          "required": ["success", "error"],
          "additionalProperties": false
        }
      ]
    },

    "BatchResultItem": {
      "type": "object",
      "description": "Result for a single operation in the batch",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based index of this operation in the request array"
        },
        "operation": {
          "type": "string",
          "description": "The operation name that was executed"
        },
        "result": {
          "$ref": "#/$defs/OperationResult",
          "description": "The individual operation result (success or failure)"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "pending_confirmation"],
          "description": "Status for skip-and-continue mode: 'pending_confirmation' when CONFIRMATION_REQUIRED"
        }
      },
      "required": ["index", "operation", "result"],
      "additionalProperties": false
    },

    "HaltedOperation": {
      "type": "object",
      "description": "Information about the operation that caused the batch to halt",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based index of the halted operation"
        },
        "operation": {
          "type": "string",
          "description": "The operation name that triggered halting"
        },
        "result": {
          "$ref": "#/$defs/OperationResult",
          "description": "The CONFIRMATION_REQUIRED result"
        }
      },
      "required": ["index", "operation", "result"],
      "additionalProperties": false
    },

    "PendingOperationItem": {
      "type": "object",
      "description": "An operation that did not execute due to batch halting",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based index of this operation in the original request"
        },
        "operation": {
          "type": "string",
          "description": "The operation name"
        },
        "params": {
          "type": "object",
          "description": "The operation parameters (for continuation)",
          "additionalProperties": true
        }
      },
      "required": ["index", "operation"],
      "additionalProperties": false
    },

    "BatchSummary": {
      "type": "object",
      "description": "Summary statistics for the batch execution",
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of operations in the batch"
        },
        "succeeded": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of operations that succeeded"
        },
        "failed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of operations that failed"
        },
        "halted": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of operations that triggered halting (CONFIRMATION_REQUIRED)"
        },
        "pending": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of operations that did not execute due to halting"
        },
        "pending_confirmation": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of operations awaiting confirmation (skip-and-continue mode)"
        }
      },
      "required": ["total", "succeeded", "failed"],
      "additionalProperties": false
    }
  },

  "oneOf": [
    {
      "type": "object",
      "title": "Batch Request",
      "description": "Request format for batch operations",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BatchOperationItem"
          },
          "minItems": 1,
          "description": "Array of operations to execute in order"
        }
      },
      "required": ["operations"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Batch Success Response",
      "description": "Successful batch response (batch completed processing or halted for confirmation)",
      "properties": {
        "success": {
          "const": true,
          "description": "Indicates batch processing completed or halted (individual ops may have failed or need confirmation)"
        },
        "data": {
          "description": "Always null for batch responses",
          "type": "null"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BatchResultItem"
          },
          "description": "Individual results for operations that executed"
        },
        "halted_at": {
          "$ref": "#/$defs/HaltedOperation",
          "description": "Present when batch halted due to CONFIRMATION_REQUIRED"
        },
        "pending_operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PendingOperationItem"
          },
          "description": "Operations that did not execute due to halting (for continuation)"
        },
        "summary": {
          "$ref": "#/$defs/BatchSummary",
          "description": "Summary statistics for the batch"
        }
      },
      "required": ["success", "results", "summary"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Batch Failure Response",
      "description": "Failed batch response (batch-level error)",
      "properties": {
        "success": {
          "const": false,
          "description": "Indicates batch-level failure (malformed request, auth failure)"
        },
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Machine-readable error code",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "message": {
              "type": "string",
              "description": "Human-readable error message"
            }
          },
          "required": ["code", "message"],
          "additionalProperties": false
        }
      },
      "required": ["success", "error"],
      "additionalProperties": false
    }
  ],

  "examples": [
    {
      "operations": [
        { "operation": "create_item", "params": { "name": "Item A", "category": "product" } },
        { "operation": "create_item", "params": { "name": "Item B", "category": "service" } }
      ]
    },
    {
      "success": true,
      "data": null,
      "results": [
        { "index": 0, "operation": "create_item", "result": { "success": true, "data": { "id": "item_1" } } },
        { "index": 1, "operation": "create_item", "result": { "success": true, "data": { "id": "item_2" } } }
      ],
      "summary": { "total": 2, "succeeded": 2, "failed": 0 }
    },
    {
      "success": true,
      "data": null,
      "results": [
        { "index": 0, "operation": "update_user", "result": { "success": true, "data": { "id": "alice" } } }
      ],
      "halted_at": {
        "index": 1,
        "operation": "delete_user",
        "result": {
          "success": false,
          "error": {
            "code": "CONFIRMATION_REQUIRED",
            "message": "This operation requires confirmation"
          }
        }
      },
      "pending_operations": [
        { "index": 2, "operation": "send_notification", "params": { "user_id": "alice", "message": "Account deleted" } }
      ],
      "summary": { "total": 3, "succeeded": 1, "failed": 0, "halted": 1, "pending": 1 }
    },
    {
      "success": false,
      "error": {
        "code": "BATCH_VALIDATION_ERROR",
        "message": "Batch request must contain at least one operation"
      }
    }
  ]
}
