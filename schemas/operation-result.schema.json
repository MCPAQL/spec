{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaql.org/schemas/operation-result.schema.json",
  "title": "MCP-AQL Operation Result",
  "description": "Schema for MCP-AQL operation response format (discriminated union)",
  "oneOf": [
    {
      "type": "object",
      "title": "Success Result",
      "properties": {
        "success": {
          "const": true,
          "description": "Indicates operation succeeded"
        },
        "data": {
          "description": "Operation result data (adapter-specific)"
        },
        "warnings": {
          "type": "array",
          "description": "Optional array of non-fatal warning conditions",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable warning code",
                "pattern": "^[A-Z][A-Z0-9_]*$"
              },
              "message": {
                "type": "string",
                "description": "Human-readable warning message"
              },
              "details": {
                "type": "object",
                "description": "Optional contextual information",
                "additionalProperties": true
              },
              "severity": {
                "type": "string",
                "description": "Optional severity level for client prioritization",
                "enum": ["low", "medium", "high"]
              }
            },
            "required": ["code", "message"],
            "additionalProperties": false
          }
        },
        "_meta": {
          "type": "object",
          "description": "Response metadata (request ID, timing, etc.)",
          "properties": {
            "request_id": {
              "type": "string",
              "description": "Unique identifier for the request"
            },
            "duration_ms": {
              "type": "number",
              "description": "Request processing time in milliseconds"
            }
          },
          "additionalProperties": true
        },
        "results": {
          "type": "array",
          "description": "Individual results for batch operations",
          "items": {
            "type": "object",
            "properties": {
              "index": {
                "type": "integer",
                "description": "Position in the original batch request"
              },
              "operation": {
                "type": "string",
                "description": "Operation name that was executed"
              },
              "result": {
                "description": "Individual operation result",
                "$ref": "#"
              }
            },
            "required": ["index", "result"]
          }
        },
        "summary": {
          "type": "object",
          "description": "Aggregate summary for batch operations",
          "properties": {
            "total": {
              "type": "integer",
              "description": "Total number of operations in batch"
            },
            "succeeded": {
              "type": "integer",
              "description": "Number of successful operations"
            },
            "failed": {
              "type": "integer",
              "description": "Number of failed operations"
            }
          },
          "required": ["total", "succeeded", "failed"]
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "title": "Failure Result",
      "description": "Error response with structured error details",
      "properties": {
        "success": {
          "const": false,
          "description": "Indicates operation failed"
        },
        "error": {
          "type": "object",
          "description": "Structured error details",
          "properties": {
            "code": {
              "type": "string",
              "description": "Machine-readable error code (e.g., VALIDATION_MISSING_PARAM)",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "message": {
              "type": "string",
              "description": "Human-readable error message"
            },
            "details": {
              "type": "object",
              "description": "Optional contextual information",
              "additionalProperties": true
            }
          },
          "required": ["code", "message"],
          "additionalProperties": false
        },
        "confirmation": {
          "type": "object",
          "description": "Confirmation flow details for gated operations (CONFIRMATION_REQUIRED errors)",
          "properties": {
            "token": {
              "type": "string",
              "description": "Confirmation token to include in retry request"
            },
            "expires_at": {
              "type": "string",
              "format": "date-time",
              "description": "When the confirmation token expires"
            },
            "message": {
              "type": "string",
              "description": "Human-readable confirmation prompt to display to user"
            },
            "reasons": {
              "type": "array",
              "description": "Reasons why confirmation is required",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["token", "expires_at"]
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this operation or response format is deprecated"
        },
        "deprecationMessage": {
          "type": "string",
          "description": "Human-readable deprecation notice"
        },
        "deprecatedSince": {
          "type": "string",
          "description": "Version when this was deprecated"
        },
        "removalVersion": {
          "type": "string",
          "description": "Version when this will be removed"
        }
      },
      "required": ["success", "error"],
      "additionalProperties": false
    }
  ]
}
